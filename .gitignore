# ==============================================================================
# CityPulse CRM — .gitignore
# ==============================================================================

# Dependencies
node_modules/
.venv/
__pycache__/
*.pyc

# Environment files (NEVER commit secrets)
.env
.env.local
.env.*.local

# Build outputs
.next/
out/
dist/
build/

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Logs
*.log
npm-debug.log*

# Type generation
.next/types/
